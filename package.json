{
  "name": "bni-lucky-draw",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ./node_modules/next/dist/bin/next dev",
    "build": "node ./node_modules/next/dist/bin/next build",
    "start": "node ./node_modules/next/dist/bin/next start",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "deploy": "npm run build && gcloud builds submit --config cloudbuild.yaml --project lucky-497805 --quiet",
    "deploy:run": "gcloud run deploy lucky-draw --image asia-east1-docker.pkg.dev/lucky-497805/cloud-run-source-deploy/lucky-draw:latest --region asia-east1 --project lucky-497805 --allow-unauthenticated --port 8080 --quiet"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.3",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3"
  }
}
